#include "comms/comms.h"
#include "CommsTestCommon.h"

CC_DISABLE_WARNINGS()
#include "cxxtest/TestSuite.h"
CC_ENABLE_WARNINGS()

#include <cstdint>
#include <cstddef>
#include <algorithm>
#include <iterator>

class SyncSuffixLayerTestSuite : public CxxTest::TestSuite
{
public:
    void test1();
    void test2();
    void test3();
    void test4();
    void test5();
    void test6();

private:

    typedef std::tuple<
        comms::option::MsgIdType<MessageType>,
        comms::option::IdInfoInterface,
        comms::option::BigEndian,
        comms::option::ReadIterator<const char*>,
        comms::option::WriteIterator<char*>,
        comms::option::LengthInfoInterface
    > BeTraits;

    typedef TestMessageBase<BeTraits> BeMsgBase;
    typedef BeMsgBase::Field BeField;

    typedef Message1<BeMsgBase> BeMsg1;
    typedef Message11<BeMsgBase> BeMsg11;

    using BeSyncField =
        comms::field::IntValue<
            BeField,
            std::uint16_t,
            comms::option::DefaultNumValue<0xabcd>
        >;

    using BeSyncField2 =
        comms::field::IntValue<
            BeField,
            std::uint16_t,
            comms::option::DefaultNumValue<0x3d3d> // ==
        >;

    using BeEscField =
        comms::field::IntValue<
            BeField,
            std::uint16_t,
            comms::option::DefaultNumValue<0x4040> // @@
        >;

    using BeSizeField =
        comms::field::IntValue<
            BeField,
            std::uint16_t
        >;

    using BeIdField =
        comms::field::EnumValue<
            BeField,
            MessageType,
            comms::option::FixedLength<1U>
        >;

    using ReadVerifyFrame =
        comms::frame::MsgSizeLayer<
            BeSizeField,
            comms::frame::MsgIdLayer<
                BeIdField,
                BeMsgBase,
                AllTestMessages<BeMsgBase>,
                comms::frame::SyncSuffixLayer<
                    BeSyncField,
                    comms::frame::MsgDataLayer<>
                >
            >
        >;

    using VerifyReadFrame =
        comms::frame::MsgSizeLayer<
            BeSizeField,
            comms::frame::MsgIdLayer<
                BeIdField,
                BeMsgBase,
                AllTestMessages<BeMsgBase>,
                comms::frame::SyncSuffixLayer<
                    BeSyncField,
                    comms::frame::MsgDataLayer<>,
                    comms::option::def::FrameLayerVerifyBeforeRead
                >
            >
        >;

    using SeekFieldFrame =
        comms::frame::SyncSuffixLayer<
            BeSyncField,
            comms::frame::MsgIdLayer<
                BeIdField,
                BeMsgBase,
                AllTestMessages<BeMsgBase>,
                comms::frame::MsgDataLayer<>
            >,
            comms::option::def::FrameLayerSeekField<>
        >;

    using SeekFieldWithEscFrame =
        comms::frame::SyncSuffixLayer<
            BeSyncField2,
            comms::frame::MsgIdLayer<
                BeIdField,
                BeMsgBase,
                AllTestMessages<BeMsgBase>,
                comms::frame::MsgDataLayer<>
            >,
            comms::option::def::FrameLayerSeekField<BeEscField>
        >;
};

void SyncSuffixLayerTestSuite::test1()
{
    static const char Buf[] = {
        0x0, 0x5, MessageType1, 0x01, 0x02, static_cast<char>(0xab), static_cast<char>(0xcd), static_cast<char>(0x3f)
    };

    static const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    ReadVerifyFrame frame;

    auto msgPtr = commonReadWriteMsgTest(frame, &Buf[0], BufSize);
    TS_ASSERT(msgPtr);
    TS_ASSERT_EQUALS(msgPtr->getId(), MessageType1);
    auto& msg1 = dynamic_cast<BeMsg1&>(*msgPtr);
    TS_ASSERT_EQUALS(std::get<0>(msg1.fields()).value(), 0x0102);
}

void SyncSuffixLayerTestSuite::test2()
{
    static const char Buf[] = {
        0x0, 0x5, MessageType1, 0x01, 0x02, static_cast<char>(0xab), static_cast<char>(0xcd), static_cast<char>(0x3f)
    };

    static const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    VerifyReadFrame frame;

    auto msgPtr = commonReadWriteMsgTest(frame, &Buf[0], BufSize);
    TS_ASSERT(msgPtr);
    TS_ASSERT_EQUALS(msgPtr->getId(), MessageType1);
    auto& msg1 = dynamic_cast<BeMsg1&>(*msgPtr);
    TS_ASSERT_EQUALS(std::get<0>(msg1.fields()).value(), 0x0102);
}

void SyncSuffixLayerTestSuite::test3()
{
    static const char Buf[] = {
        MessageType11, 'h', 'e', 'l', 'l', 'o', static_cast<char>(0xab), static_cast<char>(0xcd), static_cast<char>(0x3f)
    };

    static const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    SeekFieldFrame frame;

    auto msgPtr = commonReadWriteMsgTest(frame, &Buf[0], BufSize);
    TS_ASSERT(msgPtr);
    TS_ASSERT_EQUALS(msgPtr->getId(), MessageType11);
    auto& msg11 = dynamic_cast<BeMsg11&>(*msgPtr);
    TS_ASSERT_EQUALS(std::get<0>(msg11.fields()).value(), "hello");
}

void SyncSuffixLayerTestSuite::test4()
{
    static const char Buf[] = {
        MessageType11, 'h', 'e', '@', '@', '=', '=', 'l', 'l', 'o', '=', '=', static_cast<char>(0x3f)
    };

    static const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    SeekFieldWithEscFrame frame;
    SeekFieldWithEscFrame::MsgPtr msg;
    auto readIter = comms::readIteratorFor(msg, Buf);
    auto es = frame.read(msg, readIter, BufSize);
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    TS_ASSERT(msg);
    TS_ASSERT_EQUALS(msg->getId(), MessageType11);
    auto& msg11 = dynamic_cast<BeMsg11&>(*msg);
    TS_ASSERT_EQUALS(std::get<0>(msg11.fields()).value(), "he@@==llo");
}

void SyncSuffixLayerTestSuite::test5()
{
    // Double esc field should be ignored
    static const char Buf[] = {
        MessageType11, 'h', 'e', 'l', 'l', 'o', '@', '@', '@', '@', '=', '=', static_cast<char>(0x3f)
    };

    static const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    SeekFieldWithEscFrame frame;
    SeekFieldWithEscFrame::MsgPtr msg;
    auto readIter = comms::readIteratorFor(msg, Buf);
    auto es = frame.read(msg, readIter, BufSize);
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    TS_ASSERT(msg);
    TS_ASSERT_EQUALS(msg->getId(), MessageType11);
    auto& msg11 = dynamic_cast<BeMsg11&>(*msg);
    TS_ASSERT_EQUALS(std::get<0>(msg11.fields()).value(), "hello@@@@");
}

void SyncSuffixLayerTestSuite::test6()
{
    // Triple escape should still count as escape
    static const char Buf[] = {
        MessageType11, 'h', 'e', '@', '@', '@', '@', '@', '@', '=', '=', 'l', 'l', 'o', '=', '=', static_cast<char>(0x3f)
    };

    static const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    SeekFieldWithEscFrame frame;
    SeekFieldWithEscFrame::MsgPtr msg;
    auto readIter = comms::readIteratorFor(msg, Buf);
    auto es = frame.read(msg, readIter, BufSize);
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    TS_ASSERT(msg);
    TS_ASSERT_EQUALS(msg->getId(), MessageType11);
    auto& msg11 = dynamic_cast<BeMsg11&>(*msg);
    TS_ASSERT_EQUALS(std::get<0>(msg11.fields()).value(), "he@@@@@@==llo");
}

